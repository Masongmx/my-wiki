# Knowledge Base Configuration Template
# Copy this file to config/kb.yaml and fill in your values

knowledge_base:
  # 数据目录（存放 raw/、wiki/）
  # 可以是绝对路径，如：/path/to/your/knowledge-base
  data_dir: ./data
  
  # 或者指定外部数据目录
  # data_dir: /mnt/d/knowledge-base
  
  # 目录结构（相对于 data_dir）
  raw_dir: raw
  wiki_dir: wiki
  
  # 索引和日志
  index_file: wiki/_index.md
  log_file: wiki/_meta/log.md

llm:
  # Provider: openai, bailian, anthropic
  provider: openai
  
  # Model name
  model: gpt-4o-mini
  
  # API key (or set environment variable OPENAI_API_KEY)
  # api_key: sk-xxx
  
  # Base URL (optional, for custom endpoints)
  # base_url: https://api.openai.com/v1
  
  # For complex tasks, use a stronger model
  complex_model: gpt-4o

lint:
  # Enable/disable checks
  check_missing_pages: true
  check_orphans: true
  check_contradictions: true
  check_outdated: true
  
  # Days before content is considered outdated
  outdated_days: 365
  
  # Directories to exclude
  exclude_dirs:
    - .obsidian
    - .git
    - __pycache__

logging:
  level: INFO